#!/bin/bash
# plugin-git-pr — Push branches and create PRs for auto-dev workflows
# Usage: plugin-git-pr push | create-pr <title> [body]
set -euo pipefail

COMMAND="${1:-}"
shift || true

# ── Platform detection ──────────────────────────────────────────────────
detect_platform() {
    local remote_url
    remote_url=$(git remote get-url origin 2>/dev/null || echo "")
    if [[ "$remote_url" == *"github.com"* ]]; then
        echo "github"
    elif [[ "$remote_url" == *"gitlab"* ]]; then
        echo "gitlab"
    else
        echo "unknown"
    fi
}

# ── Parse owner/repo from remote URL ───────────────────────────────────
parse_github_repo() {
    local remote_url
    remote_url=$(git remote get-url origin 2>/dev/null || echo "")
    # Handle SSH: git@github.com:owner/repo.git
    if [[ "$remote_url" =~ github\.com[:/]([^/]+)/([^/.]+) ]]; then
        echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
    fi
}

# ── Push command ────────────────────────────────────────────────────────
cmd_push() {
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD)

    # Check if upstream exists
    if git rev-parse --abbrev-ref "@{upstream}" &>/dev/null; then
        git push 2>&1
    else
        git push -u origin "$branch" 2>&1
    fi

    echo "{\"status\":\"success\",\"branch\":\"$branch\",\"pushed\":true}"
}

# ── Create PR command ───────────────────────────────────────────────────
cmd_create_pr() {
    local title="${1:-Auto-dev PR}"
    local body="${2:-Generated by Pulse Auto-Dev}"
    local platform
    platform=$(detect_platform)
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD)
    local base_branch
    base_branch=$(git remote show origin 2>/dev/null | grep 'HEAD branch' | awk '{print $NF}' || echo "main")

    case "$platform" in
        github)
            if [[ -z "${GITHUB_TOKEN:-}" ]]; then
                echo "{\"status\":\"error\",\"error\":\"No GitHub token found. Set GITHUB_TOKEN environment variable.\"}"
                exit 1
            fi
            local repo
            repo=$(parse_github_repo)
            if [[ -z "$repo" ]]; then
                echo "{\"status\":\"error\",\"error\":\"Could not parse GitHub owner/repo from remote URL\"}"
                exit 1
            fi

            local response
            response=$(curl -s -w "\n%{http_code}" \
                -H "Authorization: token $GITHUB_TOKEN" \
                -H "Accept: application/vnd.github.v3+json" \
                -X POST "https://api.github.com/repos/$repo/pulls" \
                -d "$(jq -n --arg title "$title" --arg body "$body" --arg head "$branch" --arg base "$base_branch" \
                    '{title: $title, body: $body, head: $head, base: $base, draft: false}')")

            local http_code
            http_code=$(echo "$response" | tail -1)
            local json_body
            json_body=$(echo "$response" | sed '$d')

            if [[ "$http_code" == "201" ]]; then
                local pr_url pr_number
                pr_url=$(echo "$json_body" | jq -r '.html_url')
                pr_number=$(echo "$json_body" | jq -r '.number')
                echo "{\"status\":\"success\",\"pr_url\":\"$pr_url\",\"pr_number\":$pr_number,\"platform\":\"github\"}"
            else
                local error_msg
                error_msg=$(echo "$json_body" | jq -r '.message // "unknown error"')
                echo "{\"status\":\"error\",\"error\":\"GitHub API error ($http_code): $error_msg\",\"platform\":\"github\"}"
                exit 1
            fi
            ;;
        gitlab)
            if [[ -z "${GITLAB_TOKEN:-}" ]]; then
                echo "{\"status\":\"error\",\"error\":\"No GitLab token found. Set GITLAB_TOKEN environment variable.\"}"
                exit 1
            fi
            local base_url="${GITLAB_BASE_URL:-https://gitlab.com}"
            # Simplified — would need project ID resolution for full implementation
            echo "{\"status\":\"error\",\"error\":\"GitLab MR creation not yet implemented\"}"
            exit 1
            ;;
        *)
            echo "{\"status\":\"error\",\"error\":\"Unknown git platform. PR creation requires GitHub or GitLab.\"}"
            exit 1
            ;;
    esac
}

# ── Health check ────────────────────────────────────────────────────────
cmd_health() {
    local platform
    platform=$(detect_platform)
    local has_git=false
    local has_curl=false
    command -v git &>/dev/null && has_git=true
    command -v curl &>/dev/null && has_curl=true
    echo "{\"status\":\"healthy\",\"platform\":\"$platform\",\"git\":$has_git,\"curl\":$has_curl}"
}

# ── Info ────────────────────────────────────────────────────────────────
cmd_info() {
    echo '{"name":"plugin-git-pr","version":"0.1.0","commands":["push","create-pr","health","info"]}'
}

# ── Dispatch ────────────────────────────────────────────────────────────
case "$COMMAND" in
    push)       cmd_push ;;
    create-pr)  cmd_create_pr "$@" ;;
    health)     cmd_health ;;
    info)       cmd_info ;;
    *)
        echo "{\"status\":\"error\",\"error\":\"Unknown command: $COMMAND. Use: push, create-pr, health, info\"}"
        exit 1
        ;;
esac
