#!/usr/bin/env bash
# plugin-memory — Multi-provider knowledge graph for Pulse
# Reads provider from config/config.yaml → memory.provider
# Supported providers: gitnexus, greptile, none

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="${PULSE_CONFIG:-$SCRIPT_DIR/../config.yaml}"

# ── Read config ─────────────────────────────────────────────
read_yaml_value() {
  local key="$1" default="$2"
  if command -v yq &>/dev/null; then
    val=$(yq -r "$key // \"\"" "$CONFIG_FILE" 2>/dev/null)
  elif command -v python3 &>/dev/null; then
    val=$(python3 -c "
import yaml, sys
with open('$CONFIG_FILE') as f:
    cfg = yaml.safe_load(f) or {}
keys = '$key'.strip('.').split('.')
for k in keys:
    cfg = cfg.get(k, {}) if isinstance(cfg, dict) else {}
print(cfg if isinstance(cfg, str) else '')" 2>/dev/null)
  else
    val=""
  fi
  echo "${val:-$default}"
}

PROVIDER=$(read_yaml_value "memory.provider" "gitnexus")
AUTO_REINDEX=$(read_yaml_value "memory.auto_reindex" "true")

# Provider-specific config
GITNEXUS_PKG=$(read_yaml_value "memory.gitnexus.package" "gitnexus@latest")
GREPTILE_KEY_ENV=$(read_yaml_value "memory.greptile.api_key_env" "GREPTILE_API_KEY")
GREPTILE_REMOTE=$(read_yaml_value "memory.greptile.remote" "")

# ── Provider: none ──────────────────────────────────────────
if [ "$PROVIDER" = "none" ]; then
  COMMAND="${1:-help}"
  case "$COMMAND" in
    health) echo '{"status":"disabled","provider":"none"}' ;;
    info)   echo '{"name":"plugin-memory","version":"0.1.0","provider":"none","status":"disabled"}' ;;
    *)      echo '{"status":"skipped","provider":"none","reason":"memory disabled in config"}' ;;
  esac
  exit 0
fi

# ── Provider: gitnexus ──────────────────────────────────────
gitnexus_exec() {
  local cmd="$1"; shift
  case "$cmd" in
    index)
      local path="${1:-.}"
      exec npx -y "$GITNEXUS_PKG" analyze "$path"
      ;;
    reindex)
      local path="${1:-.}"
      exec npx -y "$GITNEXUS_PKG" analyze "$path"
      ;;
    impact)
      local symbol="${1:?Usage: plugin-memory impact <symbol>}"
      exec npx -y "$GITNEXUS_PKG" impact "$symbol"
      ;;
    context)
      local symbol="${1:?Usage: plugin-memory context <symbol>}"
      exec npx -y "$GITNEXUS_PKG" context "$symbol"
      ;;
    query)
      local query="${1:?Usage: plugin-memory query <search-term>}"
      exec npx -y "$GITNEXUS_PKG" query "$query"
      ;;
    detect-changes)
      # gitnexus has no detect-changes command; derive from git diff + impact
      local changed_symbols
      changed_symbols=$(git diff --name-only HEAD 2>/dev/null | head -20 | tr '\n' ' ')
      if [ -z "$changed_symbols" ]; then
        echo '{"status":"ok","changes":[],"message":"no uncommitted changes detected"}'
      else
        # Query the knowledge graph with the changed files for impact analysis
        exec npx -y "$GITNEXUS_PKG" query "impact of changes in: $changed_symbols" --content
      fi
      ;;
    rename)
      echo '{"status":"error","provider":"gitnexus","error":"rename not supported — use IDE refactoring tools instead"}'
      exit 1
      ;;
    mcp)
      exec npx -y "$GITNEXUS_PKG" mcp
      ;;
    health)
      if command -v npx &>/dev/null; then
        echo "{\"status\":\"healthy\",\"provider\":\"gitnexus\",\"package\":\"$GITNEXUS_PKG\",\"npx\":true}"
      else
        echo '{"status":"unhealthy","provider":"gitnexus","npx":false,"error":"npx not found"}'
        exit 1
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

# ── Provider: greptile ──────────────────────────────────────
greptile_exec() {
  local cmd="$1"; shift
  local api_key="${!GREPTILE_KEY_ENV:-}"
  if [ -z "$api_key" ] && [ "$cmd" != "health" ] && [ "$cmd" != "info" ]; then
    echo "{\"status\":\"error\",\"provider\":\"greptile\",\"error\":\"env var $GREPTILE_KEY_ENV not set\"}"
    exit 1
  fi

  local base_url="https://api.greptile.com/v2"

  case "$cmd" in
    index)
      curl -sf -X POST "$base_url/repositories" \
        -H "Authorization: Bearer $api_key" \
        -H "Content-Type: application/json" \
        -d "{\"remote\":\"$GREPTILE_REMOTE\",\"reload\":true}"
      ;;
    reindex)
      curl -sf -X POST "$base_url/repositories" \
        -H "Authorization: Bearer $api_key" \
        -H "Content-Type: application/json" \
        -d "{\"remote\":\"$GREPTILE_REMOTE\",\"reload\":true}"
      ;;
    query)
      local query="${1:?Usage: plugin-memory query <search-term>}"
      curl -sf -X POST "$base_url/query" \
        -H "Authorization: Bearer $api_key" \
        -H "Content-Type: application/json" \
        -d "{\"messages\":[{\"content\":\"$query\",\"role\":\"user\"}],\"repositories\":[{\"remote\":\"$GREPTILE_REMOTE\"}]}"
      ;;
    context|impact)
      # Greptile uses query for all lookups
      local term="${1:-}"
      local prompt="Analyze the impact and context of: $term"
      curl -sf -X POST "$base_url/query" \
        -H "Authorization: Bearer $api_key" \
        -H "Content-Type: application/json" \
        -d "{\"messages\":[{\"content\":\"$prompt\",\"role\":\"user\"}],\"repositories\":[{\"remote\":\"$GREPTILE_REMOTE\"}]}"
      ;;
    detect-changes)
      local changed_files
      changed_files=$(git diff --name-only HEAD 2>/dev/null | head -20 | tr '\n' ' ')
      if [ -z "$changed_files" ]; then
        echo '{"status":"ok","changes":[],"message":"no uncommitted changes detected"}'
      else
        local prompt="Analyze the impact of changes in these files: $changed_files"
        curl -sf -X POST "$base_url/query" \
          -H "Authorization: Bearer $api_key" \
          -H "Content-Type: application/json" \
          -d "{\"messages\":[{\"content\":\"$prompt\",\"role\":\"user\"}],\"repositories\":[{\"remote\":\"$GREPTILE_REMOTE\"}]}"
      fi
      ;;
    health)
      if [ -n "$api_key" ] && [ -n "$GREPTILE_REMOTE" ]; then
        echo "{\"status\":\"healthy\",\"provider\":\"greptile\",\"remote\":\"$GREPTILE_REMOTE\"}"
      else
        local err=""
        [ -z "$api_key" ] && err="$GREPTILE_KEY_ENV not set"
        [ -z "$GREPTILE_REMOTE" ] && err="${err:+$err, }remote not configured"
        echo "{\"status\":\"unhealthy\",\"provider\":\"greptile\",\"error\":\"$err\"}"
        exit 1
      fi
      ;;
    rename|mcp)
      echo "{\"status\":\"error\",\"provider\":\"greptile\",\"error\":\"$cmd not supported by greptile provider\"}"
      exit 1
      ;;
    *)
      return 1
      ;;
  esac
}

# ── Dispatch ────────────────────────────────────────────────
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  info)
    cat <<JSON
{
  "name": "plugin-memory",
  "version": "0.1.0",
  "description": "Multi-provider knowledge graph — codebase indexing, impact analysis, context queries",
  "provider": "$PROVIDER",
  "auto_reindex": $AUTO_REINDEX,
  "commands": ["index", "reindex", "impact", "context", "query", "detect-changes", "mcp", "health", "info"]
}
JSON
    ;;

  help)
    cat <<USAGE
plugin-memory — Multi-provider knowledge graph for Pulse

Active provider: $PROVIDER  (set in config/config.yaml → memory.provider)
Supported: gitnexus, greptile, none

Commands:
  index [path]              Full codebase index (gitnexus analyze)
  reindex [path]            Incremental re-index (gitnexus analyze, no --force)
  impact <symbol>           Blast radius analysis (upstream dependants)
  context <symbol>          360° symbol view (callers, callees, processes)
  query <search-term>       Search knowledge graph for execution flows
  detect-changes            Derive impact from git diff + knowledge graph
  mcp                       Start MCP server (gitnexus only)
  health                    Health check (JSON)
  info                      Plugin metadata (JSON)

Config (config/config.yaml):
  memory:
    provider: gitnexus|greptile|none
    auto_reindex: true|false
    gitnexus:
      package: "gitnexus@latest"
    greptile:
      api_key_env: "GREPTILE_API_KEY"
      remote: "github:owner/repo"
USAGE
    ;;

  *)
    case "$PROVIDER" in
      gitnexus) gitnexus_exec "$COMMAND" "$@" ;;
      greptile) greptile_exec "$COMMAND" "$@" ;;
      *)
        echo "{\"status\":\"error\",\"error\":\"unknown provider: $PROVIDER\"}"
        exit 1
        ;;
    esac
    ;;
esac
